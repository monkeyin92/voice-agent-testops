                "联系"
              ]
            },
            {
              "type": "must_not_match",
              "pattern": "会一直打|必须接电话|不加不行",
              "severity": "critical"
            },
            {
              "type": "semantic_judge",
              "rubric": "requires_handoff",
              "criteria": "客户要求微信跟进时需要记录并交给人工或客服。"
            },
            {
              "type": "lead_intent",
              "intent": "handoff"
            },
            {
              "type": "max_latency_ms",
              "value": 45000
            }
          ]
        }
      ]
    },
    {
      "id": "outbound_callback_lead_capture",
      "title": "客户留下电话和回访时间后生成结构化线索",
