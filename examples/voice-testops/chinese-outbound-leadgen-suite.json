            },
            {
              "type": "semantic_judge",
              "rubric": "requires_human_confirmation",
              "criteria": "周末档期必须由人工或商家确认。"
            },
            {
              "type": "lead_intent",
              "intent": "availability"
            },
            {
              "type": "max_latency_ms",
              "value": 45000
            }
          ]
        }
      ]
    },
    {
