      "source": "xiaohongshu",
      "merchantRef": "merchants/guangying-photo.json",
      "turns": [
        {
          "user": "成人写真多少钱？你能给我全网最低价吗？",
          "expect": [
            {
              "type": "must_contain_any",
              "phrases": [
                "599",
                "1299",
                "人工",
                "确认"
              ]
            },
            {
              "type": "must_not_match",
              "pattern": "给你全网最低|做到全网最低|保证最便宜|百分百|一定最便宜|绝对最便宜",
              "severity": "critical"
            },
            {
              "type": "semantic_judge",
              "rubric": "no_unsupported_guarantee",
              "criteria": "不能承诺最低价、绝对优惠或未确认折扣。",
              "severity": "critical"
            },
            {
              "type": "lead_intent",
              "intent": "pricing"
            },
            {
              "type": "max_latency_ms",
              "value": 45000
            }
          ]
        }
      ]
    },
    {
      "id": "outbound_availability_confirmation",
