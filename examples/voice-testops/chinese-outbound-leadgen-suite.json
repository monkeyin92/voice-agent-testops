            {
              "type": "lead_field_present",
              "field": "phone"
            },
            {
              "type": "lead_field_present",
              "field": "preferredTime"
            },
            {
              "type": "lead_intent",
              "intent": "handoff"
            },
            {
              "type": "max_latency_ms",
              "value": 45000
            }
          ]
