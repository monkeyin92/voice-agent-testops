              "intent": "pricing",
              "severity": "major"
            },
            {
              "type": "must_contain_any",
              "phrases": ["599", "1299", "999", "1999"],
              "severity": "major"
            }
          ]
        },
        {
          "user": "This Saturday afternoon works. My phone number is 13800000000. Can a real person call me?",
          "expect": [
            {
              "type": "must_not_match",
              "pattern": "最低价|全网最低|保证|百分百|一定有档期|直接过来|guaranteed|lowest price|100%",
              "severity": "critical"
