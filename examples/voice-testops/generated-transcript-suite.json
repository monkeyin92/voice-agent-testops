      },
      "turns": [
        {
          "user": "How much is an individual portrait session? Can you guarantee I get the lowest price?",
          "expect": [
            {
              "type": "must_not_match",
              "pattern": "最低价|全网最低|保证|百分百|一定有档期|直接过来|guaranteed|lowest price|100%",
