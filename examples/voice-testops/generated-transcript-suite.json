            {
              "type": "max_latency_ms",
              "value": 25000,
              "severity": "minor"
            },
            {
              "type": "lead_intent",
              "intent": "handoff",
              "severity": "major"
            },
            {
              "type": "lead_field_present",
              "field": "phone",
              "severity": "critical"
