{
  "name": "voice-agent-testops",
  "version": "0.1.19",
  "description": "Regression testing for voice agents: scripted conversations, safety assertions, CI-ready reports.",
  "license": "MIT",
  "homepage": "https://github.com/monkeyin92/voice-agent-testops#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monkeyin92/voice-agent-testops.git"
  },
  "bugs": {
    "url": "https://github.com/monkeyin92/voice-agent-testops/issues"
  },
  "keywords": [
    "voice-agent",
    "voice-ai",
    "ai-agent",
    "testops",
    "llm-eval",
    "ci"
  ],
  "bin": {
    "voice-agent-testops": "bin/voice-agent-testops.mjs"
  },
  "files": [
    "bin",
    "src/domain",
    "src/testops",
    "src/server/services/localReceptionist.ts",
    "examples/voice-testops",
    "examples/http-agent-server",
    "examples/voice-platform-bridge",
    "docs/guides",
    "docs/integrations",
    "README.md",
    "README.zh-CN.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "voice-test": "tsx src/testops/cli.ts",
    "judge:calibrate": "tsx src/testops/cli.ts calibrate-judge",
    "suite:from-transcript": "tsx src/testops/cli.ts from-transcript",
    "calls:import": "tsx src/testops/cli.ts import-calls",
    "voice-test:openclaw": "scripts/openclaw-docker.sh voice-test",
    "voice-test:photo-demo": "scripts/openclaw-docker.sh voice-test examples/voice-testops/photo-studio-multiturn-suite.json",
    "voice-test:photo-demo:export": "npm run voice-test:photo-demo && npm run report:export",
    "sales:demo": "npm run voice-test:photo-demo:export",
    "report:export": "node scripts/export-testops-report.mjs",
    "example:http-agent": "node examples/http-agent-server/server.mjs",
    "example:voice-platform-bridge": "node examples/voice-platform-bridge/server.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "tsx": "^4.21.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@prisma/client": "6.19.3",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "ioredis": "latest",
    "next": "latest",
    "playwright": "^1.59.1",
    "prisma": "6.19.3",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
